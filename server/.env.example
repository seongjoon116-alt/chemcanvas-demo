# DeepSeek API key (발급: https://platform.deepseek.com/api_keys)
DEEPSEEK_API_KEY=

# 사용할 모델 ID (기본값: deepseek-v4-0424)
# 선택지: deepseek-v4-0424 | deepseek-v4-pro | deepseek-v4-flash
DEEPSEEK_MODEL=deepseek-v4-0424

# 서버 포트
PORT=3001

# PubChem API key (선택, 없으면 5req/s / 있으면 10req/s)
# 무료 발급: https://pubchem.ncbi.nlm.nih.gov/docs/programmatic-access#section=API-Keys
PUBCHEM_API_KEY=
